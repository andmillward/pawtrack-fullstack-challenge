{
  // Production build config: same options as tsconfig.json but excludes test
  // files so `npm run build` never emits *.test.* into dist/. The IDE and
  // `npm run typecheck` use tsconfig.json, which includes tests (with
  // esModuleInterop) so they are still type-checked.
  "extends": "./tsconfig.json",
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
